version: '3.8'
services:
  app:
    build: .
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
    depends_on:
      - db
  db:
    image: {{ 'postgres:15' if 'PostgreSQL' in database else 'mongo:6' if 'MongoDB' in database else 'mysql:8' }}
    environment:
      POSTGRES_USER: user
      POSTGRES_PASSWORD: pass
      POSTGRES_DB: {{ project_name }}
    volumes:
      - db_data:/var/lib/postgresql/data
volumes:
  db_data: